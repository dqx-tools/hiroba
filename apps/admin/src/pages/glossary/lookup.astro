---
import Layout from "../../layouts/Layout.astro";
import GlossaryLookup from "../../components/GlossaryLookup";
---

<Layout title="Glossary Lookup">
	<GlossaryLookup client:load />
</Layout>

<style is:global>
	.glossary-lookup {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.input-section textarea {
		width: 100%;
		padding: 0.75rem;
		font-size: 1rem;
		border: 1px solid var(--color-border, #ccc);
		border-radius: 4px;
		resize: vertical;
		font-family: inherit;
	}

	.input-section .actions {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: 0.75rem;
	}

	.input-section .hint {
		color: var(--color-muted, #666);
		font-size: 0.875rem;
	}

	.results-section h3 {
		margin: 0 0 1rem 0;
		font-size: 1.1rem;
	}
</style>
