---
import Layout from "../../layouts/Layout.astro";
import { createDb, getNewsItem, translations as translationsTable } from "@hiroba/db";
import { CATEGORY_LABELS, type Category } from "@hiroba/shared";
import { and, eq } from "drizzle-orm";

const { id } = Astro.params;

if (!id) {
	return Astro.redirect("/");
}

const runtime = Astro.locals.runtime;
const db = createDb(runtime.env.DB);

// Get the news item metadata from D1
const item = await getNewsItem(db, id);
if (!item) {
	return new Response("Not found", { status: 404 });
}

// Check for existing translations
const existingTranslations = await db
	.select()
	.from(translationsTable)
	.where(
		and(
			eq(translationsTable.itemType, "news"),
			eq(translationsTable.itemId, id),
			eq(translationsTable.language, "en"),
		),
	)
	.all();

const titleTranslation = existingTranslations.find((t) => t.field === "title");
const contentTranslation = existingTranslations.find((t) => t.field === "content");

// Determine content state
const hasTranslations = !!titleTranslation;
const hasContent = !!item.contentJa;

// If no content or no translations, trigger workflow (fire and forget)
if (!hasContent || !hasTranslations) {
	try {
		const doId = runtime.env.WORKFLOW_MANAGER.idFromName(id);
		const stub = runtime.env.WORKFLOW_MANAGER.get(doId);

		stub.fetch(
			new Request("http://internal/trigger", {
				method: "POST",
				body: JSON.stringify({ itemId: id }),
				headers: { "Content-Type": "application/json" },
			}),
		);
	} catch (error) {
		console.error(`Workflow trigger failed for ${id}:`, error);
	}
}

// Use translations if available, otherwise fall back to Japanese
const title = titleTranslation?.value ?? item.titleJa;
const content = contentTranslation?.value ?? item.contentJa ?? "";
const translatedAt = titleTranslation?.translatedAt ?? 0;
const isTranslated = !!titleTranslation;
const categoryLabel = CATEGORY_LABELS[item.category as Category] || item.category;
---

<Layout title={title}>
	<article>
		<header>
			<div class="meta">
				<a href={`/category/${item.category}`} class="category">{categoryLabel}</a>
				<time datetime={new Date(item.publishedAt * 1000).toISOString()}>
					{new Date(item.publishedAt * 1000).toLocaleDateString("en-US", {
						year: "numeric",
						month: "long",
						day: "numeric",
					})}
				</time>
			</div>
			<h1>{title}</h1>
		</header>

		{!hasContent && (
			<div class="loading-notice">
				<p>Content is being fetched. Please refresh in a moment.</p>
			</div>
		)}

		{hasContent && !isTranslated && (
			<div class="translation-notice">
				<p>Translation in progress. Showing original Japanese content.</p>
			</div>
		)}

		{content && (
			<div class="content" set:html={content} />
		)}

		{translatedAt > 0 && (
			<footer class="translation-info">
				<p>
					Translated on {new Date(translatedAt * 1000).toLocaleDateString("en-US", {
						year: "numeric",
						month: "long",
						day: "numeric",
					})}
				</p>
				<details>
					<summary>View original Japanese</summary>
					<div class="original">
						<h2>{item.titleJa}</h2>
						{item.contentJa && (
							<div class="content" set:html={item.contentJa} />
						)}
					</div>
				</details>
			</footer>
		)}

		<nav class="back-link">
			<a href="/">← Back to home</a>
		</nav>
	</article>
</Layout>

<style>
	article {
		max-width: 100%;
	}

	header {
		margin-bottom: 1.5rem;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 0.5rem;
		color: var(--color-muted);
		font-size: 0.9rem;
	}

	.category {
		text-transform: uppercase;
		font-size: 0.8rem;
		background: #eee;
		padding: 0.2rem 0.5rem;
		border-radius: 3px;
		text-decoration: none;
		color: var(--color-text);
	}

	.category:hover {
		background: #ddd;
	}

	h1 {
		font-size: 1.75rem;
		line-height: 1.3;
	}

	.loading-notice,
	.translation-notice {
		background: #fff3cd;
		border: 1px solid #ffc107;
		padding: 1rem;
		border-radius: 4px;
		margin-bottom: 1.5rem;
	}

	.loading-notice p,
	.translation-notice p {
		margin: 0;
		color: #856404;
	}

	.content {
		line-height: 1.8;
		margin-bottom: 2rem;
		white-space: pre-wrap;
	}

	.translation-info {
		margin-top: 2rem;
		padding-top: 1rem;
		border-top: 1px solid #eee;
		color: var(--color-muted);
		font-size: 0.9rem;
	}

	details {
		margin-top: 1rem;
	}

	summary {
		cursor: pointer;
		color: var(--color-link);
	}

	.original {
		margin-top: 1rem;
		padding: 1rem;
		background: #f5f5f5;
		border-radius: 4px;
	}

	.original h2 {
		font-size: 1.25rem;
		margin-bottom: 1rem;
	}

	.back-link {
		margin-top: 2rem;
	}
</style>
